# Copy to .env and fill in real values. Never commit the real .env file.

MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=battle
MYSQL_USER=battleapp
MYSQL_PASSWORD=

# Flask session signing key.
SECRET_KEY=

# Required for AI-generated feedback (analysis/battles still work with rule-based
# scoring and generic feedback if this is unset).
OPENAI_API_KEY=

# Optional: raises the GitHub API rate limit from 60/hour to 5000/hour.
GITHUB_TOKEN=
